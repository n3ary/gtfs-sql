{
  "name": "@gtfs/rt",
  "version": "0.0.0",
  "private": true,
  "description": "Live GTFS-RT adapter — polls upstream feeds, applies per-feed quirks, publishes a clean FeedMessage. Issue #34 step 7.",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest --run"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@n3ary/gtfs-adapter-cluj-napoca": "^0.3.4",
    "@n3ary/gtfs-spec": "workspace:*",
    "fastify": "^5.0.0",
    "gtfs-realtime-bindings": "^1.1.1",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "protobufjs": "^7.4.0",
    "zod": "^4.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "license": "PolyForm-Noncommercial-1.0.0"
}
