# Local config for the RT adapter. Copy to .env (not committed) and
# tweak. The deploy unit (Step 9) reads these via systemd's
# EnvironmentFile= directive.

# Required. URL or local path of feeds.json.
FEEDS_JSON=https://gtfs.n3ary.com/feeds.json

# Optional. Defaults shown.
PORT=8080
HOST=0.0.0.0
POLL_INTERVAL_MS=15000
UPSTREAM_TIMEOUT_MS=10000
LOG_LEVEL=info

# Optional. Comma-separated feed IDs to enable. Empty = all feeds in
# the registry. Useful for staging a single feed before rolling out
# to all.
# ENABLED_FEEDS=cluj-napoca
