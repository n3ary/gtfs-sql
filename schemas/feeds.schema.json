{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ciotlosm/neary-gtfs/schemas/feeds.schema.json",
  "title": "neary-gtfs app-facing feed registry",
  "description": "The feeds.json catalog published to the Cloudflare R2 bucket (gtfs.n3ary.com) and consumed by the neary PWA on launch.",
  "type": "object",
  "required": ["version", "generated_at", "feeds"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string", "format": "date-time" },
    "generated_at": { "type": "string", "format": "date-time" },
    "feeds": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/feed" }
    }
  },
  "$defs": {
    "feed": {
      "type": "object",
      "required": [
        "id", "name", "country", "timezone", "bbox", "center",
        "agencies", "source", "files", "size_bytes", "hash",
        "generated_at", "license"
      ],
      "additionalProperties": false,
      "properties": {
        "id":       { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "name":     { "type": "string", "minLength": 1 },
        "country":  { "type": "string", "pattern": "^[A-Z]{2}$" },
        "region":   { "type": "string" },
        "timezone": { "type": "string", "minLength": 1 },
        "languages": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z]{2,3}$" }
        },
        "bbox": {
          "type": "object",
          "required": ["minLat", "minLon", "maxLat", "maxLon"],
          "additionalProperties": false,
          "properties": {
            "minLat": { "type": "number", "minimum": -90,  "maximum": 90 },
            "minLon": { "type": "number", "minimum": -180, "maximum": 180 },
            "maxLat": { "type": "number", "minimum": -90,  "maximum": 90 },
            "maxLon": { "type": "number", "minimum": -180, "maximum": 180 }
          }
        },
        "center": {
          "type": "object",
          "required": ["lat", "lon"],
          "additionalProperties": false,
          "properties": {
            "lat": { "type": "number", "minimum": -90,  "maximum": 90 },
            "lon": { "type": "number", "minimum": -180, "maximum": 180 }
          }
        },
        "agencies": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["agency_name"],
            "additionalProperties": false,
            "properties": {
              "agency_id":   { "type": ["string", "null"] },
              "agency_name": { "type": "string", "minLength": 1 },
              "agency_url":  { "type": ["string", "null"], "format": "uri" }
            }
          }
        },
        "source": {
          "type": "object",
          "required": ["type", "publisher"],
          "additionalProperties": false,
          "properties": {
            "type":          { "enum": ["transitous", "mobility-database", "remote"] },
            "publisher":     { "type": "string", "minLength": 1 },
            "upstream_url":  { "type": ["string", "null"], "format": "uri", "description": "URL of the upstream zip. For type=transitous/mobility-database, the resolved Transitous mirror; for type=remote, the externally-built GTFS zip declared in feeds/<id>/config.json source.url." },
            "upstream_etag": { "type": ["string", "null"], "description": "HTTP ETag of upstream zip. Used to skip download + convert when upstream hasn't changed." }
          }
        },
        "files": {
          "type": "object",
          "required": ["sqlite_gz"],
          "additionalProperties": false,
          "properties": {
            "sqlite_gz": { "type": "string", "minLength": 1 }
          }
        },
        "size_bytes": {
          "type": "object",
          "required": ["sqlite_gz"],
          "additionalProperties": false,
          "properties": {
            "sqlite_gz": { "type": "integer", "minimum": 0 }
          }
        },
        "hash":         { "type": "string", "pattern": "^sha256-[a-f0-9]{64}$" },
        "generated_at": { "type": "string", "format": "date-time" },
        "valid_from":   { "type": ["string", "null"], "format": "date" },
        "valid_until":  { "type": ["string", "null"], "format": "date" },
        "realtime": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "properties": {
            "vehicle_positions": { "type": "string", "format": "uri" },
            "trip_updates":      { "type": "string", "format": "uri" },
            "service_alerts":    { "type": "string", "format": "uri" }
          }
        },
        "tranzy": {
          "type": "object",
          "description": "Optional. Mapping for the Tranzy.ai advanced signal (used only when a user supplies an API key in app settings). Absent means this feed cannot be augmented with Tranzy.",
          "required": ["agency_id"],
          "additionalProperties": false,
          "properties": {
            "agency_id": { "type": "string", "minLength": 1 }
          }
        },
        "license": {
          "type": "object",
          "required": ["attribution_text"],
          "additionalProperties": false,
          "properties": {
            "spdx_identifier":  { "type": ["string", "null"] },
            "attribution_text": { "type": "string", "minLength": 1 },
            "attribution_url":  { "type": ["string", "null"], "format": "uri" }
          }
        }
      }
    }
  }
}
