# rt.env -- environment for the neary-gtfs-rt systemd unit.

FEEDS_JSON=https://gtfs.n3ary.com/feeds.json

# In-container listen port. Host 80 -> this port via podman -p 80:8080
# in neary-gtfs-rt.service; keep these in sync.
PORT=8080

# 15 s is long enough to not hammer upstreams, short enough that a missed
# poll shows up quickly.
POLL_INTERVAL_MS=15000

# 10 s covers a slow upstream without making a wedged feed look "down" too fast.
UPSTREAM_TIMEOUT_MS=10000

# Empty means all feeds in the registry.
ENABLED_FEEDS=cluj-napoca

# info is plenty in production; debug for chasing upstream-quirk regressions.
LOG_LEVEL=info
