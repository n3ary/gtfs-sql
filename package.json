{
  "name": "neary-gtfs",
  "version": "0.2.41-m1",
  "private": true,
  "type": "module",
  "description": "GTFS publisher: static + RT packages for the neary PWA.",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "scripts": {
    "pipeline": "pnpm --filter @gtfs/static pipeline",
    "test": "pnpm -r --parallel test",
    "test:static": "pnpm --filter @gtfs/static test",
    "build": "pnpm -r --filter './apps/*' --filter './libs/*' build",
    "check": "pnpm -r --filter './apps/*' --filter './libs/*' check",
    "lint": "pnpm -r --parallel lint"
  },
  "devDependencies": {
    "typescript": "^6.0.0"
  },
  "license": "PolyForm-Noncommercial-1.0.0"
}
