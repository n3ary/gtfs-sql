{
  "name": "neary-gtfs",
  "version": "0.2.20-m1",
  "private": true,
  "type": "module",
  "description": "Producer monorepo for the neary PWA — packages/static (offline pipeline), packages/rt (live RT adapter), packages/shared (@ciotlosm/neary-gtfs-core).",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "scripts": {
    "pipeline": "pnpm --filter @gtfs/static pipeline",
    "test": "pnpm -r --parallel test",
    "test:static": "pnpm --filter @gtfs/static test",
    "build": "pnpm -r --filter './packages/*' build",
    "check": "pnpm -r --filter './packages/*' check",
    "lint": "pnpm -r --parallel lint"
  },
  "devDependencies": {
    "typescript": "^6.0.0"
  },
  "license": "PolyForm-Noncommercial-1.0.0"
}
